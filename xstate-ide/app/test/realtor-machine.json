{
  "id": "realtor_bot",
  "initial": "ask_email",
  "context": {
    "user_email": "",
    "status": "",
    "order": "",
    "timing": "",
    "phone": "",
    "inputError": null,
    "trace": [],
    "_trace": null
  },
  "states": {
    "ask_email": {
      "meta": {
        "text": "Welcome! Please enter your email address.",
        "input": "text",
        "placeholder": "email@example.com"
      },
      "on": {
        "SUBMIT": [
          {
            "guard": "isValidEmail",
            "target": "ask_status",
            "actions": [
              {
                "type": "updateContext",
                "params": {
                  "inputError": null,
                  "mapValueTo": "user_email"
                }
              },
              "record"
            ]
          },
          {
            "actions": [
              {
                "type": "updateContext",
                "params": {
                  "inputError": "Please provide a valid email address (e.g. name@example.com)."
                }
              },
              "recordValidationFailure"
            ]
          }
        ]
      }
    },
    "ask_status": {
      "meta": {
        "text": "Do you rent or own your current home?"
      },
      "on": {
        "RENT": {
          "target": "ask_timing",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "status": "rent"
              }
            },
            "record"
          ]
        },
        "OWN": {
          "target": "ask_order",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "status": "own"
              }
            },
            "record"
          ]
        }
      }
    },
    "ask_order": {
      "meta": {
        "text": "Would you like to buy first or sell first?"
      },
      "on": {
        "BUY_FIRST": {
          "target": "ask_timing",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "order": "buy_first"
              }
            },
            "record"
          ]
        },
        "SELL_FIRST": {
          "target": "ask_timing",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "order": "sell_first"
              }
            },
            "record"
          ]
        }
      }
    },
    "ask_timing": {
      "meta": {
        "text": "When are you planning to move?"
      },
      "on": {
        "SOON": {
          "target": "ask_phone",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "timing": "soon"
              }
            },
            "record"
          ]
        },
        "LATER": {
          "target": "ask_phone",
          "actions": [
            {
              "type": "updateContext",
              "params": {
                "timing": "later"
              }
            },
            "record"
          ]
        }
      }
    },
    "ask_phone": {
      "meta": {
        "text": "What is your phone number?",
        "input": "text",
        "placeholder": "e.g. 4155550123"
      },
      "on": {
        "SUBMIT": [
          {
            "guard": "isValidPhone",
            "target": "route_by_timing",
            "actions": [
              {
                "type": "updateContext",
                "params": {
                  "inputError": null,
                  "mapValueTo": "phone"
                }
              },
              "record"
            ]
          },
          {
            "actions": [
              {
                "type": "updateContext",
                "params": {
                  "inputError": "Please enter a valid phone number (7\u201320 digits)."
                }
              },
              "recordValidationFailure"
            ]
          }
        ]
      }
    },
    "route_by_timing": {
      "always": [
        {
          "guard": "isSoon",
          "target": "closing_soon"
        },
        {
          "guard": "isLater",
          "target": "closing_later"
        }
      ]
    },
    "closing_soon": {
      "meta": {
        "text": "Great news \u2014 let's get you booked in! We'll reach out via email to {{user_email}} at {{phone}} to schedule your appointment about . Talk {{timing}}! \ud83c\udfe1\n\nWould you like a transcript of this conversation emailed to {{user_email}}?"
      },
      "on": {
        "YES": {
          "target": "send_transcript",
          "actions": [
            "record"
          ]
        },
        "NO": {
          "target": "upload_context",
          "actions": [
            "record"
          ]
        }
      }
    },
    "closing_later": {
      "meta": {
        "text": "No rush! We'll check in with you {{timing}} at {{user_email}} when the timing is right. Thanks for chatting! \ud83d\udc4b\n\nWould you like a transcript of this conversation emailed to {{user_email}}?"
      },
      "on": {
        "YES": {
          "target": "send_transcript",
          "actions": [
            "record"
          ]
        },
        "NO": {
          "target": "upload_context",
          "actions": [
            "record"
          ]
        }
      }
    },
    "send_transcript": {
      "meta": {
        "text": "Got it! A transcript will be emailed to {{user_email}} shortly."
      },
      "invoke": {
        "id": "emailTranscript",
        "src": "emailTranscript",
        "onDone": {
          "target": "upload_context",
          "actions": [
            "recordService"
          ]
        },
        "onError": {
          "target": "upload_context",
          "actions": [
            "recordService"
          ]
        }
      }
    },
    "upload_context": {
      "invoke": {
        "id": "uploadContext",
        "src": "uploadContext",
        "onDone": {
          "target": "finish_screen",
          "actions": [
            "recordService"
          ]
        },
        "onError": {
          "target": "finish_screen",
          "actions": [
            "recordService"
          ]
        }
      }
    },
    "finish_screen": {
      "type": "final",
      "meta": {
        "text": "All done \u2014 thanks for chatting! We'll be in touch {{timing}}. \ud83d\ude0a"
      }
    }
  },
  "entry": [
    "initTrace"
  ]
}
