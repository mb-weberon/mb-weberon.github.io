{
  "id": "subscription",
  "initial": "trialing",

  "context": {
    "subscriptionId": "",
    "userId": "",
    "planId": "",
    "stripeSubscriptionId": "",
    "retryCount": 0,
    "pausedAt": null,
    "cancelledAt": null,
    "trialEndsAt": null,
    "trace": [],
    "_trace": null
  },

  "entry": ["initTrace"],

  "states": {

    "trialing": {
      "meta": {
        "text": "User is within their free trial period. Full product access granted. Stripe has a future invoice scheduled.",
        "access": "full"
      },
      "on": {
        "TRIAL_CONVERTED": {
          "target": "active",
          "actions": ["recordTransition", "grantFullAccess", "record"],
          "http": {
            "source": "stripe_webhook",
            "stripeEvent": "customer.subscription.updated",
            "guard": "trialJustEnded"
          },
          "responses": {
            "onDone":    { "status": 200, "body": { "state": "active" } },
            "onError":   { "status": 500, "body": { "error": "transition_failed" } }
          }
        },
        "CANCEL": {
          "target": "cancelled",
          "actions": ["recordTransition", "setCancelledAt", "revokeAccess", "notifyUser", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/cancel"
          },
          "schema": {
            "type": "object",
            "properties": {
              "reason": { "type": "string" },
              "feedback": { "type": "string" }
            }
          },
          "responses": {
            "onDone":       { "status": 200, "body": { "state": "cancelled" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_cancel_in_current_state" } }
          }
        }
      }
    },

    "active": {
      "meta": {
        "text": "Subscription is paid and current. Full product access granted.",
        "access": "full"
      },
      "on": {
        "PAYMENT_FAILED": {
          "target": "past_due",
          "actions": ["recordTransition", "incrementRetryCount", "notifyUser", "record"],
          "http": {
            "source": "stripe_webhook",
            "stripeEvent": "invoice.payment_failed"
          },
          "responses": {
            "onDone":  { "status": 200, "body": { "state": "past_due" } },
            "onError": { "status": 500, "body": { "error": "transition_failed" } }
          }
        },
        "CANCEL": {
          "target": "cancelled",
          "actions": ["recordTransition", "setCancelledAt", "revokeAccess", "notifyUser", "cancelStripeSubscription", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/cancel"
          },
          "schema": {
            "type": "object",
            "properties": {
              "reason":   { "type": "string" },
              "feedback": { "type": "string" }
            }
          },
          "responses": {
            "onDone":       { "status": 200, "body": { "state": "cancelled" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_cancel_in_current_state" } }
          }
        }
      }
    },

    "past_due": {
      "meta": {
        "text": "Payment has failed. Stripe is retrying automatically. User retains access during retry window. Retry schedule is managed by Stripe's Smart Retries.",
        "access": "full"
      },
      "invoke": {
        "src": "watchRetryWindow",
        "onDone": {
          "target": "past_due",
          "actions": ["recordTransition", "recordService"]
        },
        "onError": {
          "target": "paused",
          "actions": ["recordTransition", "setPausedAt", "revokeAccess", "notifyUser", "recordService"]
        }
      },
      "on": {
        "PAYMENT_RECOVERED": {
          "target": "active",
          "actions": ["recordTransition", "resetRetryCount", "notifyUser", "record"],
          "http": {
            "source": "stripe_webhook",
            "stripeEvent": "invoice.paid"
          },
          "responses": {
            "onDone":  { "status": 200, "body": { "state": "active" } },
            "onError": { "status": 500, "body": { "error": "transition_failed" } }
          }
        },
        "RETRIES_EXHAUSTED": {
          "target": "paused",
          "actions": ["recordTransition", "setPausedAt", "revokeAccess", "notifyUser", "record"],
          "http": {
            "source": "stripe_webhook",
            "stripeEvent": "customer.subscription.updated",
            "guard": "statusIsPastDueAndMaxRetries"
          },
          "responses": {
            "onDone":  { "status": 200, "body": { "state": "paused" } },
            "onError": { "status": 500, "body": { "error": "transition_failed" } }
          }
        }
      }
    },

    "paused": {
      "meta": {
        "text": "Access suspended after payment retries exhausted. Subscription still exists in Stripe but is paused. User can self-serve resume by updating payment method.",
        "access": "none"
      },
      "on": {
        "RESUME": {
          "target": "active",
          "actions": ["recordTransition", "resetRetryCount", "grantFullAccess", "notifyUser", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/resume"
          },
          "invoke": {
            "src": "chargeAndResumeStripe",
            "onDone":  { "target": "active",  "actions": ["recordTransition", "grantFullAccess"] },
            "onError": { "target": "paused",   "actions": ["recordTransition", "notifyUser"] }
          },
          "responses": {
            "onDone":       { "status": 200, "body": { "state": "active" } },
            "onError":      { "status": 402, "body": { "error": "payment_failed_on_resume" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_resume_in_current_state" } }
          }
        },
        "CANCEL": {
          "target": "cancelled",
          "actions": ["recordTransition", "setCancelledAt", "cancelStripeSubscription", "notifyUser", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/cancel"
          },
          "responses": {
            "onDone":       { "status": 200, "body": { "state": "cancelled" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_cancel_in_current_state" } }
          }
        }
      }
    },

    "cancelled": {
      "meta": {
        "text": "Subscription ended, voluntarily or after expiry. No access. Stripe subscription deleted. Re-activation creates a new Stripe subscription.",
        "access": "none"
      },
      "on": {
        "REACTIVATE": {
          "target": "active",
          "actions": ["recordTransition", "resetRetryCount", "grantFullAccess", "notifyUser", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/reactivate"
          },
          "schema": {
            "type": "object",
            "required": ["planId", "paymentMethodId"],
            "properties": {
              "planId":           { "type": "string" },
              "paymentMethodId":  { "type": "string" }
            }
          },
          "invoke": {
            "src": "createNewStripeSubscription",
            "onDone":  { "target": "active",     "actions": ["recordTransition", "grantFullAccess"] },
            "onError": { "target": "cancelled",  "actions": ["recordTransition", "notifyUser"] }
          },
          "responses": {
            "onDone":       { "status": 201, "body": { "state": "active" } },
            "onError":      { "status": 402, "body": { "error": "payment_failed_on_reactivation" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_reactivate_in_current_state" } }
          }
        }
      }
    },

    "expired": {
      "meta": {
        "text": "Trial ended without conversion, or system-level expiry. No Stripe subscription exists. Terminal unless user reactivates.",
        "access": "none"
      },
      "on": {
        "REACTIVATE": {
          "target": "active",
          "actions": ["recordTransition", "grantFullAccess", "notifyUser", "record"],
          "http": {
            "source": "user",
            "method": "POST",
            "path": "/subscriptions/:id/reactivate"
          },
          "schema": {
            "type": "object",
            "required": ["planId", "paymentMethodId"],
            "properties": {
              "planId":           { "type": "string" },
              "paymentMethodId":  { "type": "string" }
            }
          },
          "invoke": {
            "src": "createNewStripeSubscription",
            "onDone":  { "target": "active",  "actions": ["recordTransition", "grantFullAccess"] },
            "onError": { "target": "expired", "actions": ["recordTransition", "notifyUser"] }
          },
          "responses": {
            "onDone":       { "status": 201, "body": { "state": "active" } },
            "onError":      { "status": 402, "body": { "error": "payment_failed_on_reactivation" } },
            "invalidState": { "status": 422, "body": { "error": "cannot_reactivate_in_current_state" } }
          }
        }
      }
    }
  }
}
