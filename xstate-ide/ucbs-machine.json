{
  "id": "ucbs_bot",
  "initial": "ask_timing",
  "context": {
    "user_email": "",
    "phone": "",
    "status": "",
    "order": "",
    "area": "",
    "season": "",
    "has_realtor": "",
    "committed": "",
    "call_time": "",
    "inputError": null,
    "trace": []
  },
  "states": {

    "ask_timing": {
      "meta": {
        "text": "Welcome. Are you thinking of making a move in the next 3 to 6 months?"
      },
      "on": {
        "YES": {
          "target": "ask_status",
          "actions": [
            { "type": "updateContext", "params": { "timing": "within_6_months" } },
            "record"
          ]
        },
        "MORE_THAN_6_MONTHS": {
          "target": "finish_screen",
          "actions": [
            { "type": "updateContext", "params": { "timing": "later" } },
            "record"
          ]
        }
      }
    },

    "ask_status": {
      "meta": {
        "text": "Do you currently Rent or Own your home?"
      },
      "on": {
        "RENT": {
          "target": "ask_area",
          "actions": [
            { "type": "updateContext", "params": { "status": "rent" } },
            "record"
          ]
        },
        "OWN": {
          "target": "ask_order",
          "actions": [
            { "type": "updateContext", "params": { "status": "own" } },
            "record"
          ]
        }
      }
    },

    "ask_order": {
      "meta": {
        "text": "Do you want to Buy first or Sell first?"
      },
      "on": {
        "BUY_FIRST": {
          "target": "ask_area",
          "actions": [
            { "type": "updateContext", "params": { "order": "buy_first" } },
            "record"
          ]
        },
        "SELL_FIRST": {
          "target": "ask_season_sell",
          "actions": [
            { "type": "updateContext", "params": { "order": "sell_first" } },
            "record"
          ]
        }
      }
    },

    "ask_area": {
      "meta": {
        "text": "If you were to move, are you planning on staying in the same area or moving out of the area?"
      },
      "on": {
        "STAYING_IN_AREA": {
          "target": "ask_season_buy",
          "actions": [
            { "type": "updateContext", "params": { "area": "in_area" } },
            "record"
          ]
        },
        "MOVING_OUT_OF_AREA": {
          "target": "ask_season_buy",
          "actions": [
            { "type": "updateContext", "params": { "area": "out_of_area" } },
            "record"
          ]
        }
      }
    },

    "ask_season_sell": {
      "meta": {
        "text": "If you were to move, when do you think that might be?"
      },
      "on": {
        "THIS_SEASON": {
          "target": "ask_realtor_sell",
          "actions": [
            { "type": "updateContext", "params": { "season": "this_season" } },
            "record"
          ]
        },
        "NEXT_SEASON": {
          "target": "ask_realtor_sell",
          "actions": [
            { "type": "updateContext", "params": { "season": "next_season" } },
            "record"
          ]
        }
      }
    },

    "ask_season_buy": {
      "meta": {
        "text": "If you were to move, when do you think that might be?"
      },
      "on": {
        "THIS_SEASON": {
          "target": "ask_realtor_buy",
          "actions": [
            { "type": "updateContext", "params": { "season": "this_season" } },
            "record"
          ]
        },
        "NEXT_SEASON": {
          "target": "ask_realtor_buy",
          "actions": [
            { "type": "updateContext", "params": { "season": "next_season" } },
            "record"
          ]
        }
      }
    },

    "ask_realtor_sell": {
      "meta": {
        "text": "Do you have a Realtor to help you when the time is right?"
      },
      "on": {
        "YES": {
          "target": "ask_committed_sell",
          "actions": [
            { "type": "updateContext", "params": { "has_realtor": "yes" } },
            "record"
          ]
        },
        "NO": {
          "target": "offer_eval_tips",
          "actions": [
            { "type": "updateContext", "params": { "has_realtor": "no" } },
            "record"
          ]
        }
      }
    },

    "ask_realtor_buy": {
      "meta": {
        "text": "Do you have a Realtor to help you when the time is right?"
      },
      "on": {
        "YES": {
          "target": "ask_committed_buy",
          "actions": [
            { "type": "updateContext", "params": { "has_realtor": "yes" } },
            "record"
          ]
        },
        "NO": {
          "target": "offer_off_market",
          "actions": [
            { "type": "updateContext", "params": { "has_realtor": "no" } },
            "record"
          ]
        }
      }
    },

    "ask_committed_sell": {
      "meta": {
        "text": "Not all Realtors are the same. Are you 100% committed to this Realtor OR are you open to hearing how we can 'Guarantee the sale of your home or we will buy it'?"
      },
      "on": {
        "YES_COMMITTED": {
          "target": "finish_screen",
          "actions": [
            { "type": "updateContext", "params": { "committed": "yes" } },
            "record"
          ]
        },
        "OPEN_TO_HEAR": {
          "target": "offer_eval_tips",
          "actions": [
            { "type": "updateContext", "params": { "committed": "open" } },
            "record"
          ]
        }
      }
    },

    "ask_committed_buy": {
      "meta": {
        "text": "Not all Realtors are the same with the value that they provide. Are you 100% committed to this Realtor OR are you open to hearing how we help our clients in finding homes that fit your dreams, including off-market homes?"
      },
      "on": {
        "YES_COMMITTED": {
          "target": "finish_screen",
          "actions": [
            { "type": "updateContext", "params": { "committed": "yes" } },
            "record"
          ]
        },
        "OPEN_TO_HEAR": {
          "target": "offer_off_market",
          "actions": [
            { "type": "updateContext", "params": { "committed": "open" } },
            "record"
          ]
        }
      }
    },

    "offer_off_market": {
      "meta": {
        "text": "Would you like me to notify you of homes that match your home buying criteria? This includes any Distress Sales, Bank Foreclosures and homes that are NOT available online. It is a FREE service and you're never obligated to buy a home. Would that interest you?"
      },
      "on": {
        "YES": {
          "target": "ask_phone",
          "actions": [ "record" ]
        },
        "NO": {
          "target": "finish_screen",
          "actions": [ "record" ]
        }
      }
    },

    "offer_eval_tips": {
      "meta": {
        "text": "We can give you tips on what to do and what not to do to sell your home for more money, and we can go over all the various closing costs so you know exactly what you'll have left in your pocket. It is a FREE service and obligates you to nothing. Does this sound helpful?"
      },
      "on": {
        "YES": {
          "target": "ask_phone",
          "actions": [ "record" ]
        },
        "NO": {
          "target": "finish_screen",
          "actions": [ "record" ]
        }
      }
    },

    "ask_phone": {
      "meta": {
        "text": "What is the best phone number to call you?",
        "input": "text",
        "placeholder": "e.g. (415) 555-0123"
      },
      "on": {
        "SUBMIT": [
          {
            "guard": "isValidPhone",
            "target": "ask_email",
            "actions": [
              {
                "type": "updateContext",
                "params": { "inputError": null, "mapValueTo": "phone" }
              },
              "record"
            ]
          },
          {
            "actions": [
              {
                "type": "updateContext",
                "params": { "inputError": "Please enter a valid US phone number (e.g. 415-555-0123)." }
              }
            ]
          }
        ]
      }
    },

    "ask_email": {
      "meta": {
        "text": "What is the best email to communicate with you?",
        "input": "text",
        "placeholder": "email@example.com"
      },
      "on": {
        "SUBMIT": [
          {
            "guard": "isValidEmail",
            "target": "ask_call_time",
            "actions": [
              {
                "type": "updateContext",
                "params": { "inputError": null, "mapValueTo": "user_email" }
              },
              "record"
            ]
          },
          {
            "actions": [
              {
                "type": "updateContext",
                "params": { "inputError": "Please provide a valid email address (e.g. name@example.com)." }
              }
            ]
          }
        ]
      }
    },

    "ask_call_time": {
      "meta": {
        "text": "What is the best time for us to call you?"
      },
      "on": {
        "AFTERNOON": {
          "target": "confirm_afternoon",
          "actions": [
            { "type": "updateContext", "params": { "call_time": "afternoon" } },
            "record"
          ]
        },
        "EVENING": {
          "target": "confirm_evening",
          "actions": [
            { "type": "updateContext", "params": { "call_time": "evening" } },
            "record"
          ]
        }
      }
    },

    "confirm_afternoon": {
      "meta": {
        "text": "We will call you this afternoon to set up an appointment. Thank you for chatting with us!"
      },
      "on": {
        "FINISH": {
          "target": "upload_context",
          "actions": [ "record" ]
        }
      }
    },

    "confirm_evening": {
      "meta": {
        "text": "We will call you this evening to set up an appointment. Thank you for chatting with us!"
      },
      "on": {
        "FINISH": {
          "target": "upload_context",
          "actions": [ "record" ]
        }
      }
    },

    "upload_context": {
      "invoke": {
        "id": "uploadContext",
        "src": "uploadContext",
        "onDone": { "target": "finish_screen" },
        "onError": { "target": "finish_screen" }
      }
    },

    "finish_screen": {
      "type": "final",
      "meta": {
        "text": "Goodbye! We look forward to connecting with you soon. 😊"
      }
    }

  }
}
